{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "small_model": "openai/gpt-5.3-codex",
  "provider": {
    "openai": {
      "options": {
        "timeout": false,
        "chunkTimeout": 1800000
      }
    }
  },
  "plugin": ["opencode-agent-memory"],
  "agent": {
    "assistant": {
      "model": "openai/gpt-5.3-codex",
      "description": "Otto — your 24/7 personal assistant",
      "mode": "primary",
      "color": "#4ECDC4",
      "temperature": 0.3,
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "set_prompt_file": "ask",
        "external_directory": "allow",
        "memory_*": "allow",
      },
    },
    "build": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
  },
  "default_agent": "assistant",
  "instructions": ["AGENTS.md"],
  "permission": "allow",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
}
